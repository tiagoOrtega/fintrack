# FinTrack — Environment Variables
# Copy this file to .env and fill in the values you need.
# The app works without any of these — they enable optional features.

# ── Google Sheets Backup ──────────────────────────────────────────────────────
# Required to enable the Google Sheets backup feature in Settings.
# Setup: Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0
# Client ID → Desktop app. Then enable the Google Sheets API.
# Authorized redirect URI to add: http://localhost:5173/settings
VITE_GOOGLE_CLIENT_ID=

# ── Open Finance Brasil ───────────────────────────────────────────────────────
# Required to connect Brazilian bank accounts via the Banks page.
# Register at: https://web.directory.openbankingbrasil.org.br
# Leave as default (fintrack-client) to test against bank sandbox environments.
VITE_OFB_CLIENT_ID=fintrack-client

# Proxy base URL — change only if you run the proxy on a different port.
# Default: http://localhost:3001 (start with: npm run proxy)
VITE_PROXY_URL=http://localhost:3001
