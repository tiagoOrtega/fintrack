# FinTrack — Environment Variables
# Copy this file to .env and fill in the values you need.
# JWT_SECRET is required for login; the rest enable optional features.

# ── Login ──────────────────────────────────────────────────────────────────────
# Required for real, persistent login sessions. If unset, the proxy generates
# a random secret at startup and warns — every restart invalidates all
# sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional — how long a login session lasts before requiring re-login.
JWT_EXPIRES_IN=30d

# ── Google Sheets Backup & Google Login ─────────────────────────────────────────
# Required to enable "Continue with Google" login and the Google Sheets backup
# feature in Settings (the same client ID powers both — signing in with Google
# also connects Sheets backup as a side effect).
# Setup: Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0
# Client ID → Desktop app. Then enable the Google Sheets API.
# Authorized redirect URIs to add: http://localhost:5173/login
#                              and http://localhost:5173/settings
# Read both client-side (Vite, VITE_ prefix) and server-side (server/auth.js,
# as the expected audience when verifying Google login tokens) — same value.
VITE_GOOGLE_CLIENT_ID=

# ── Open Finance Brasil ───────────────────────────────────────────────────────
# Required to connect Brazilian bank accounts via the Banks page.
# Register at: https://web.directory.openbankingbrasil.org.br
# Leave as default (fintrack-client) to test against bank sandbox environments.
VITE_OFB_CLIENT_ID=fintrack-client

# Proxy base URL — change only if you run the proxy on a different port.
# Default: http://localhost:3001 (start with: npm run proxy)
# The proxy is required for login — the app can no longer run standalone.
VITE_PROXY_URL=http://localhost:3001
